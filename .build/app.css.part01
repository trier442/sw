:root{--forest:#294e3d;--forest-2:#19382b;--sage:#dce9df;--sage-2:#eef5f0;--cream:#f7f4ec;--paper:#fff;--ink:#1f2a25;--muted:#6d7973;--line:#dce4df;--red:#b42318;--red-bg:#fee9e7;--gold:#9b6a18;--shadow:0 18px 48px rgba(35,61,49,.09)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:#f4f7f5;color:var(--ink);font-family:Pretendard,"Noto Sans KR","Apple SD Gothic Neo",Arial,sans-serif;line-height:1.55}a{color:inherit;text-decoration:none}button,input,textarea{font:inherit}.topbar{height:68px;background:rgba(255,255,255,.96);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 max(22px,5vw);position:sticky;top:0;z-index:30;backdrop-filter:blur(12px)}.brand{display:flex;align-items:center;gap:10px;font-weight:900;letter-spacing:-.03em;font-size:20px}.brand-mark{display:grid;place-items:center;width:34px;height:34px;border-radius:50%;background:var(--forest);color:#fff;font-family:Georgia,serif}.topnav{display:flex;align-items:center;gap:18px;font-size:14px}.account-chip{padding:7px 11px;border-radius:999px;background:var(--sage-2);color:var(--forest);font-weight:800}.inline-form{display:inline}.nav-button{padding:0;border:0;background:none;color:var(--ink);cursor:pointer}.container{max-width:1180px;margin:0 auto;padding:44px 24px 90px}.site-footer{text-align:center;color:var(--muted);font-size:13px;padding:28px;border-top:1px solid var(--line);background:#fff}.eyebrow{margin:0;color:#547866;font-weight:900;font-size:12px;letter-spacing:.15em}.muted{color:var(--muted)}h1,h2,h3,p{word-break:keep-all}.page-heading{display:flex;justify-content:space-between;gap:24px;align-items:flex-end;margin-bottom:28px}.page-heading h1{margin:5px 0 7px;font-size:36px;line-height:1.15;letter-spacing:-.045em}.hero-heading{align-items:center}.heading-actions,.form-actions,.result-actions,.action-bar{display:flex;align-items:center;gap:10px;flex-wrap:wrap}.button{border:0;border-radius:11px;padding:11px 17px;font-weight:850;font-size:14px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:.2s}.button.primary{background:var(--forest);color:#fff}.button.primary:hover{background:var(--forest-2);transform:translateY(-1px)}.button.secondary{background:var(--sage);color:var(--forest-2)}.button.ghost{background:#edf1ef;color:#435049}.button.danger{background:var(--red-bg);color:var(--red)}.button.disabled{background:#e7ebe9;color:#929b96;pointer-events:none}.button.wide{width:100%}.text-link{color:#2e6750;font-weight:850}.mini-button{border:0;padding:6px 9px;border-radius:7px;background:#edf2ef;color:var(--forest);font-weight:800;cursor:pointer}.panel{background:#fff;border:1px solid var(--line);border-radius:17px;padding:24px;margin-bottom:20px;box-shadow:0 4px 20px rgba(35,61,49,.03)}.panel h2{margin:0 0 8px}.narrow{max-width:760px}.panel-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;flex-wrap:wrap;margin-bottom:16px}.flash{padding:13px 16px;border-radius:11px;margin-bottom:17px;font-weight:750}.flash.success{background:#dff7e7;color:#116c3b}.flash.error{background:var(--red-bg);color:var(--red)}.auth-shell{min-height:calc(100vh - 220px);display:grid;grid-template-columns:1.15fr .85fr;gap:72px;align-items:center;padding:30px 0}.auth-copy h1{font-size:56px;line-height:1.06;margin:12px 0 24px;letter-spacing:-.055em}.auth-copy>p:not(.eyebrow){font-size:19px;max-width:620px;color:#5a675f}.feature-pills{display:flex;flex-wrap:wrap;gap:9px;margin-top:28px}.feature-pills span{padding:8px 13px;border-radius:999px;background:var(--sage);color:var(--forest);font-weight:850;font-size:13px}.auth-card{background:#fff;border:1px solid var(--line);border-radius:21px;padding:36px;box-shadow:var(--shadow)}.auth-card h2{font-size:28px;margin:0}.stack-form{display:grid;gap:18px;margin-top:25px}.stack-form label,.form-grid label{display:grid;gap:8px;font-weight:800;font-size:14px}input,textarea{width:100%;border:1px solid #ca