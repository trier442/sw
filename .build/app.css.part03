41,78,61,.2)}.sticky-submit{position:fixed;z-index:20;bottom:18px;left:50%;transform:translateX(-50%);width:min(720px,calc(100% - 30px));display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.97);border:1px solid var(--line);border-radius:14px;padding:12px 14px;box-shadow:0 14px 40px rgba(31,45,38,.16)}.result-hero{background:var(--forest);color:#fff;border-radius:22px;padding:34px;display:flex;align-items:center;justify-content:space-between;gap:25px}.result-hero h1{font-size:31px;margin:5px 0 7px}.result-hero .eyebrow{color:#bed3c5}.big-score{font-size:72px;font-weight:950;line-height:1}.big-score small{font-size:18px}.result-actions{justify-content:flex-end;margin:16px 0}.result-list{display:grid;gap:11px}.result-item{background:#fff;border:1px solid var(--line);border-left-width:5px;border-radius:13px;padding:18px;display:grid;grid-template-columns:42px 1fr;gap:12px}.result-item.correct{border-left-color:#2d8a52}.result-item.wrong{border-left-color:#d54b43}.result-number{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;background:#eef2ef;font-weight:900}.result-item h2{font-size:17px;margin:0}.result-item h2 span{font-size:11px;padding:4px 7px;border-radius:6px;background:#eef2ef;margin-left:7px}.result-item p{margin:5px 0;color:var(--muted)}.explanation{padding:11px 13px;border-radius:9px;background:#f6f7f6;font-size:14px}.concept-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.concept-section{background:#fff;border:1px solid var(--line);border-radius:17px;padding:23px}.concept-section h2{display:flex;justify-content:space-between;margin:0 0 15px}.concept-section small{font-size:12px;color:var(--muted)}.concept-section ol{list-style:none;padding:0;margin:0;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}.concept-section li{border:1px solid var(--line);border-radius:9px;padding:9px;background:#fbfcfb;display:flex;gap:7px;min-width:0}.concept-section li span{color:var(--muted);font-size:12px}.concept-section li strong{font-size:13px;overflow:hidden;text-overflow:ellipsis}.staff-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}.staff-stats article{background:#fff;border:1px solid var(--line);border-radius:15px;padding:19px}.staff-stats span{display:block;color:var(--muted);font-size:13px}.staff-stats strong{font-size:33px}.staff-stats small{font-size:14px}.upload-row{display:flex;gap:12px;align-items:center;flex-wrap:wrap}.upload-row input[type=file],.drop-form input[type=file]{padding:9px;background:#f8faf8}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse}th,td{text-align:left;border-bottom:1px solid var(--line);padding:13px 10px;vertical-align:middle}th{font-size:12px;color:var(--muted);white-space:nowrap}td{font-size:14px}td small{color:var(--muted)}code{background:#edf2ef;color:var(--forest);padding:3px 6px;border-radius:5px}.empty-cell{text-align:center;color:var(--muted);padding:30px}.score-chip{background:var(--sage);color:var(--forest);border-radius:6px;padding:4px 7px;font-weight:850}.session-status-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px}.session-status-grid article{display:grid;grid-template-columns:40px 1fr auto;align-items:center;gap:11px;padding:12px;border:1px solid var(--line);border-radius:10px}.session-status-grid>article>span{font-family:Georgia,serif;font-size:22px;color:var(--forest)}.session-status-grid strong,.session-status-grid small{display:block}.session-status-grid small{color:var(--muted)}.activity-list{display:grid}.activity-list>a,.activity-list>div{display:grid;grid-template-columns:1fr 2fr auto;gap:14px;padding:12px 5px;border-bottom:1px solid var(--line);align-items:center}.activity-list time{color:var(--muted);font-size:12px}.upload-hero{display:grid;grid-template-columns:1.2fr .8fr;gap:35px;align-items:center;padding:34px}.upload-hero ol{padding-left:21px;color:var(--muted)}.drop-form{background:var(--sage-2);bor