d5cf;border-radius:10px;padding:12px 13px;background:#fff;color:var(--ink)}input:focus,textarea:focus{outline:3px solid rgba(65,112,87,.12);border-color:#5c826d}.form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.form-grid .full{grid-column:1/-1}.average-pair{display:grid;grid-template-columns:repeat(2,minmax(150px,1fr));gap:10px}.average-pair.left{max-width:500px;margin-bottom:22px}.average-pair article{background:var(--forest);color:#fff;border-radius:15px;padding:16px 20px;min-width:175px}.average-pair span{display:block;color:#d6e5dc;font-size:12px;font-weight:700}.average-pair strong{font-size:29px;line-height:1.15}.average-pair small{font-size:13px;margin-left:3px}.progress-note{background:var(--cream);border:1px solid #e6dfcf;border-radius:13px;padding:15px 18px;margin-bottom:20px;color:#5f5848}.worksheet-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.worksheet-card{background:#fff;border:1px solid var(--line);border-radius:17px;padding:21px;display:flex;flex-direction:column;min-height:290px;box-shadow:0 8px 25px rgba(34,58,47,.04);transition:.22s}.worksheet-card:hover{transform:translateY(-3px);box-shadow:var(--shadow)}.worksheet-card.complete{border-color:#83a992;background:linear-gradient(180deg,#fff,#f4faf6)}.card-top{display:flex;justify-content:space-between;align-items:center}.session-no{font-family:Georgia,serif;font-size:34px;color:var(--forest);font-weight:700}.ready-dot{font-size:11px;padding:5px 8px;border-radius:999px;font-weight:850}.ready-dot.ready{background:#e0f4e6;color:#17643a}.ready-dot.waiting{background:#f1f1ee;color:#777}.worksheet-card h2{font-size:20px;margin:17px 0 7px;letter-spacing:-.035em}.worksheet-card p{font-size:13px;color:var(--muted);flex:1}.status-row{display:flex;gap:7px;margin:14px 0;flex-wrap:wrap}.status-row span{font-size:11px;padding:5px 8px;border-radius:7px;background:#eef1ef;color:#737e78}.status-row span.done{background:var(--sage);color:var(--forest);font-weight:800}.task-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.task-card{position:relative;background:#fff;border:1px solid var(--line);border-radius:18px;padding:26px;min-height:275px;display:flex;flex-direction:column}.task-card h2{margin:20px 0 8px}.task-card p{color:var(--muted);flex:1}.task-card.locked{background:#f0f2f1}.task-card.unlocked{background:linear-gradient(145deg,#eef8f1,#fff);border-color:#85aa93}.task-index{width:34px;height:34px;display:grid;place-items:center;border-radius:50%;background:var(--forest);color:#fff;font-weight:900}.score-badge{display:inline-block;background:var(--sage);color:var(--forest);font-weight:900;border-radius:8px;padding:7px 10px;margin:0 0 13px}.action-bar{justify-content:flex-end;margin-top:18px}.empty-state{min-height:380px;display:grid;place-items:center;text-align:center;align-content:center;gap:12px;background:#fff;border:1px dashed #bdcac3;border-radius:18px;padding:35px}.error-mark{width:54px;height:54px;border-radius:50%;display:grid;place-items:center;background:var(--red-bg);color:var(--red);font-size:30px;font-weight:900}.answer-form{padding-bottom:90px}.answer-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.answer-item{margin:0;background:#fff;border:1px solid var(--line);border-radius:13px;padding:15px}.answer-item legend{padding:0 6px;display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted)}.answer-item legend strong{display:grid;place-items:center;width:25px;height:25px;border-radius:50%;background:var(--forest);color:#fff}.choice-row{display:grid;grid-template-columns:repeat(5,1fr);gap:7px}.choice-row label{cursor:pointer}.choice-row input{position:absolute;opacity:0;pointer-events:none}.choice-row span{display:grid;place-items:center;height:43px;border:1px solid #cdd8d2;border-radius:9px;font-size:19px;background:#fff}.choice-row input:checked+span{background:var(--forest);color:#fff;border-color:var(--forest);box-shadow:0 5px 14px rgba(