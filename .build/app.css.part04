der:1px dashed #93aa9e;border-radius:14px;padding:23px;display:grid;gap:13px}.drop-form small{text-align:center;color:var(--muted)}.score-report{width:min(800px,100%);margin:0 auto;background:#fff;border:1px solid #cfdad4;border-radius:3px;padding:42px;color:#17251e;box-shadow:var(--shadow)}.score-report header{display:flex;justify-content:space-between;gap:20px;border-bottom:4px solid var(--forest);padding-bottom:23px}.score-report header span{color:#638071;font-weight:850;letter-spacing:.08em}.score-report header h1{font-size:32px;margin:5px 0}.score-report header p{margin:0;color:var(--muted)}.report-session{display:grid;place-items:center;align-content:center;width:95px;height:95px;border-radius:50%;background:var(--forest);color:#fff}.report-session strong{font-size:40px;line-height:1}.report-session span{color:#dceadf;letter-spacing:0}.report-topic{padding:17px;background:var(--cream);margin:22px 0;font-weight:750}.report-scores{display:grid;grid-template-columns:1fr 1fr;gap:14px}.report-scores article{border:1px solid var(--line);padding:24px;text-align:center}.report-scores span{color:var(--muted)}.report-scores strong{font-size:54px;display:block;color:var(--forest)}.report-scores small{font-size:16px}.report-scores p{margin:0;color:var(--muted)}.report-summary{margin-top:17px;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}.report-summary div{display:flex;justify-content:space-between;padding:12px 4px;border-bottom:1px solid var(--line)}.report-summary div:last-child{border:0}.score-report footer{display:flex;justify-content:space-between;margin-top:28px;color:var(--muted);font-size:13px}.score-report footer strong{color:var(--forest)}.share-text{display:block;width:min(800px,100%);margin:18px auto;height:75px}.issued-panel{background:#f8fcf9}.privacy-note{color:var(--muted);font-size:13px}
@media(max-width:900px){.auth-shell{grid-template-columns:1fr;gap:35px}.auth-copy h1{font-size:45px}.worksheet-grid{grid-template-columns:repeat(2,1fr)}.task-grid{grid-template-columns:1fr}.concept-grid{grid-template-columns:1fr}.upload-hero{grid-template-columns:1fr}.answer-grid{grid-template-columns:1fr}}
@media(max-width:650px){.topbar{height:auto;min-height:62px;padding:12px 16px}.brand{font-size:17px}.topnav{gap:10px}.account-chip,.topnav>a{display:none}.container{padding:30px 15px 75px}.page-heading,.hero-heading{align-items:flex-start;flex-direction:column}.page-heading h1{font-size:29px}.auth-copy h1{font-size:39px}.auth-copy>p:not(.eyebrow){font-size:16px}.auth-card{padding:25px}.worksheet-grid{grid-template-columns:1fr}.worksheet-card{min-height:250px}.average-pair{width:100%}.average-pair article{min-width:0}.form-grid{grid-template-columns:1fr}.form-grid .full{grid-column:auto}.staff-stats{grid-template-columns:1fr}.session-status-grid{grid-template-columns:1fr}.concept-section ol{grid-template-columns:repeat(2,1fr)}.activity-list>a,.activity-list>div{grid-template-columns:1fr;gap:2px}.result-hero{align-items:flex-start}.big-score{font-size:55px}.score-report{padding:23px}.score-report header h1{font-size:24px}.report-session{width:74px;height:74px}.report-session strong{font-size:31px}.report-scores strong{font-size:43px}.choice-row span{height:40px}.no-print{display:flex}}
@media print{.topbar,.site-footer,.no-print,.flash{display:none!important}.container{padding:0}.score-report{box-shadow:none;border:0;width:100%}}
.progress-table th,.progress-table td{text-align:center;min-width:34px;padding:10px 6px}.progress-table th:first-child,.progress-table td:first-child{text-align:left;position:sticky;left:0;background:#fff;z-index:2;min-width:110px}.progress-dot{display:inline-block;width:14px;height:14px;border-radius:50%;background:#d9dfdc}.progress-dot.state-1{background:#a9c8b5}.progress-dot.state-2{background:#2f7652;box-shadow:0 0 0 3px #e1f0e7}
